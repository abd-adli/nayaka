<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Server Error | Nayakatrip</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen flex items-center justify-center font-sans antialiased">
  <div class="text-center p-8 max-w-xl bg-slate-800/50 rounded-3xl border border-slate-700/50 backdrop-blur-xl shadow-2xl">
    <div class="text-6xl font-black text-transparent bg-clip-text bg-gradient-to-r from-rose-500 to-amber-500 mb-4 animate-pulse">500</div>
    <h1 class="text-2xl font-bold text-white mb-2">Unexpected Turbulence</h1>
    <p class="text-slate-400 mb-6 leading-relaxed">Our server encountered an internal error. Please sit tight while we correct our course.</p>
    <% if (typeof error !== 'undefined') { %>
      <div class="p-4 bg-red-950/40 rounded-xl border border-red-900/30 text-left text-xs font-mono text-red-400 mb-8 max-h-40 overflow-y-auto">
        <%= error %>
      </div>
    <% } %>
    <a href="/" class="inline-block px-8 py-3 rounded-full bg-gradient-to-r from-rose-500 to-amber-500 text-white font-semibold hover:-translate-y-1 active:translate-y-0 shadow-lg shadow-rose-500/20 transition-all duration-300">
      Return Home
    </a>
  </div>
</body>
</html>
