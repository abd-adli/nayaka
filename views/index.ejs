  <script>
    // Mobile menu toggle logic
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const menuIcon = document.getElementById('menu-icon');

    function toggleMobileMenu() {
      const isHidden = mobileMenu.classList.contains('hidden');
      if (isHidden) {
        mobileMenu.classList.remove('hidden');
        void mobileMenu.offsetWidth; // force reflow
        mobileMenu.classList.remove('scale-95', 'opacity-0');
        menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
      } else {
        mobileMenu.classList.add('scale-95', 'opacity-0');
        menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
        setTimeout(() => {
          mobileMenu.classList.add('hidden');
        }, 300);
      }
    }

    if (mobileMenuBtn) {
      mobileMenuBtn.addEventListener('click', toggleMobileMenu);
    }

    // Modal logic
    const modal = document.getElementById('booking-modal');
    const modalContent = document.getElementById('booking-modal-content');
    const modalTripId = document.getElementById('modal-trip-id');
    const modalTripTitle = document.getElementById('modal-trip-title');
    const modalTripPrice = document.getElementById('modal-trip-price');

    function openBookingModal(tripId, tripTitle, tripPrice) {
      modalTripId.value = tripId;
      modalTripTitle.textContent = tripTitle;
      modalTripPrice.textContent = `$${parseFloat(tripPrice).toLocaleString()}`;
      
      modal.classList.remove('hidden');
      void modal.offsetWidth;
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modalContent.classList.remove('scale-95');
    }

    function closeBookingModal() {
      modal.classList.add('opacity-0', 'pointer-events-none');
      modalContent.classList.add('scale-95');
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 300);
    }

    modal.addEventListener('click', function(e) {
      if (e.target === modal) {
        closeBookingModal();
      }
    });
  </script>
