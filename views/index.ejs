            <input 
              type="text" 
              name="customerName" 
              id="customerName" 
              required
              placeholder="e.g. John Doe"
              class="w-full px-4 py-2.5 sm:py-3 rounded-lg sm:rounded-xl bg-white/5 border border-white/15 text-white placeholder-white/30 text-xs sm:text-sm focus:outline-none focus:border-brand-500 focus:bg-white/10 transition-all"
            >
