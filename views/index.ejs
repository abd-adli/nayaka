    <!-- Glassmorphic Modal Box -->
    <div 
      class="glass-card-dark text-white w-full max-w-md p-6 sm:p-8 rounded-2xl sm:rounded-[2rem] border border-white/20 shadow-2xl relative transform scale-95 transition-all duration-300 max-h-[90vh] overflow-y-auto"
